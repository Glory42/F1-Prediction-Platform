---
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
}
const { title = 'F1 Prediction — Race Prediction Platform' } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FastF1-powered analytics engine delivering race prediction intelligence, driver performance models, and telemetry-grade insights." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased selection:bg-accent-primary selection:text-white">

    <Navbar />

    <main>
      <slot />
    </main>

    <Footer variant="full" />

  </body>
</html>

<style is:global>
  @import '../styles/globals.css';
</style>
