---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { api } from '@/lib/api';
import { DriverCompareTool } from '@/components/DriverCompareTool';
import { Users } from 'lucide-react';
import type { Driver, SeasonSummary } from '@/types';

const year = Number(Astro.url.searchParams.get('year') ?? new Date().getFullYear());

let seasons: SeasonSummary[] = [];
let initialDrivers: Driver[] = [];
let allDrivers: Driver[] = [];
let error: string | null = null;
try {
  const [seasonsData, driversData, searchData] = await Promise.all([
    api.getSeasons(),
    api.getDrivers(year),
    api.getGlobalSearch()
  ]);
  seasons = seasonsData;
  initialDrivers = driversData;
  allDrivers = searchData.drivers;
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to initialize comparison';
}
---

<BaseLayout title="Driver Head-to-Head Comparison">
  <div class="mt-7 space-y-8">
    
    {/* Page Header */}
    <div>
      <div class="flex items-center gap-3 mb-2">
        <span class="flex items-center gap-1.5 font-mono text-[9px] tracking-[0.25em] uppercase" style="color: rgba(168,85,247,0.55)">
          <Users size={11} />./drivers
        </span>
        <span class="font-mono text-[9px] tracking-[0.25em] uppercase text-muted-foreground">/</span>
        <span class="font-mono text-[9px] tracking-[0.25em] uppercase text-white">compare</span>
        <div class="h-px w-16 bg-white/[0.05]" />
      </div>
      <h1 class="text-3xl font-bold tracking-tight">Driver Comparison</h1>
      <p class="mt-1 font-mono text-[10px] text-muted-foreground tracking-widest uppercase">
        Compare F1 drivers head-to-head across seasons and career statistics
      </p>
    </div>

    {error ? (
      <div class="border border-destructive/40 bg-destructive/10 p-8 text-center">
        <p class="font-mono text-[10px] text-destructive tracking-widest uppercase">Failed to initialize compare page</p>
        <p class="mt-2 font-mono text-[9px] text-muted-foreground">{error}</p>
      </div>
    ) : (
      <DriverCompareTool allSeasons={seasons} initialDrivers={initialDrivers} allDrivers={allDrivers} client:load />
    )}

  </div>
</BaseLayout>
