---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CircuitsGrid } from '@/components/CircuitsGrid';
import { api } from '@/lib/api';
import type { Circuit } from '@/types';

let circuits: Circuit[] = [];
let error: string | null = null;

try {
  circuits = await api.getCircuits();
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load circuits';
}
---

<BaseLayout title="Circuits Directory">
  <div class="mt-7 space-y-8">
    
    {/* Page Header */}
    <div class="flex flex-col sm:flex-row sm:items-baseline justify-between flex-wrap gap-4">
      <div class="space-y-1">
        <div class="flex items-center gap-2">
          <span class="font-mono text-[9px] tracking-[0.25em] uppercase text-[#a855f7]/70">./directory</span>
          <div class="h-px w-8 bg-white/[0.05]" />
        </div>
        <h1 class="text-3xl font-bold tracking-tight">Circuits</h1>
      </div>
      <div class="font-mono text-[9px] text-muted-foreground tracking-widest uppercase mt-2 sm:mt-0">
        Total Tracks: <span class="font-bold text-[#a855f7]">{circuits.length}</span>
      </div>
    </div>
    {error ? (
      <div class="border border-destructive/40 bg-destructive/10 p-8 text-center">
        <p class="font-mono text-[10px] text-destructive tracking-widest uppercase">Error loading circuits</p>
        <p class="mt-2 font-mono text-[9px] text-muted-foreground">{error}</p>
      </div>
    ) : (
      <CircuitsGrid initialCircuits={circuits} client:load />
    )}
    
  </div>
</BaseLayout>
