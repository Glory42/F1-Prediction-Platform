---
interface Props {
  years: { year: number; raceCount: number }[];
  currentYear: number;
  basePath: string;
  extraParams?: string;
}
const { years, currentYear, basePath, extraParams = '' } = Astro.props;
const activeYears = years.filter((y) => y.raceCount > 0);
const uid = `ys-${Math.random().toString(36).slice(2, 7)}`;
---

<div class="relative" id={uid}>
  <!-- Trigger button — matches active pill style -->
  <button
    type="button"
    id={`${uid}-btn`}
    class="flex items-center gap-2 font-mono text-[9px] tracking-[0.12em] uppercase px-3 py-1.5 border border-[rgba(168,85,247,0.5)] text-[#a855f7] bg-[rgba(168,85,247,0.08)] hover:bg-[rgba(168,85,247,0.14)] transition-colors duration-150 focus:outline-none"
  >
    {currentYear}
    <span id={`${uid}-arrow`} class="text-[8px] transition-transform duration-150">▾</span>
  </button>

  <!-- Dropdown panel — 6 rows visible, rest scrollable -->
  <div
    id={`${uid}-panel`}
    class="absolute right-0 top-full mt-1 z-50 hidden border border-[rgba(168,85,247,0.25)] bg-[#080808] min-w-[80px]"
    style="max-height: calc(6 * 34px); overflow-y: auto;"
  >
    {activeYears.map((s) => (
      <a
        href={`${basePath}?year=${s.year}${extraParams}`}
        class={`block px-4 py-2 font-mono text-[9px] tracking-[0.12em] uppercase transition-colors duration-100 ${
          s.year === currentYear
            ? 'text-[#a855f7] bg-[rgba(168,85,247,0.12)]'
            : 'text-muted-foreground hover:text-foreground hover:bg-white/[0.04]'
        }`}
      >
        {s.year}
      </a>
    ))}
  </div>
</div>

<script is:inline define:vars={{ uid }}>
  const btn   = document.getElementById(`${uid}-btn`);
  const panel = document.getElementById(`${uid}-panel`);
  const arrow = document.getElementById(`${uid}-arrow`);

  function open() {
    panel.classList.remove('hidden');
    arrow.style.transform = 'rotate(180deg)';
  }
  function close() {
    panel.classList.add('hidden');
    arrow.style.transform = '';
  }

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    panel.classList.contains('hidden') ? open() : close();
  });

  document.addEventListener('click', close);
</script>
