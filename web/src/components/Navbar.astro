---
import { Home, Flag, Users, Building2, Cpu, Search, Menu, X } from 'lucide-react';
import { GlobalSearch } from '@/components/GlobalSearch';

const currentPath = Astro.url.pathname;

const links = [
  { href: '/',           label: 'home',       icon: Home       },
  {
    href: '/races',
    label: 'races',
    icon: Flag,
    dropdown: [
      { href: '/races',    label: 'seasons'  },
      { href: '/circuits', label: 'circuits' },
    ]
  },
  {
    href: '/drivers',
    label: 'drivers',
    icon: Users,
    dropdown: [
      { href: '/drivers',         label: 'standings' },
      { href: '/drivers/compare', label: 'comparison' },
    ]
  },
  {
    href: '/teams',
    label: 'teams',
    icon: Building2,
    dropdown: [
      { href: '/teams',         label: 'standings' },
      { href: '/teams/compare', label: 'comparison' },
    ]
  },
  { href: '/prediction', label: 'prediction', icon: Cpu        },
];

function isActive(href: string, dropdown?: { href: string }[]) {
  if (href === '/') return currentPath === '/';
  if (currentPath.startsWith(href)) return true;
  if (dropdown && dropdown.some((sub) => currentPath.startsWith(sub.href))) return true;
  return false;
}
---

<!-- Desktop & Mobile Top Bar -->
<header class="fixed top-0 left-0 right-0 z-50 h-[48px] bg-black border-b border-white/[0.06]">

  <div class="h-full flex items-center justify-between sm:justify-center px-5 sm:px-0 relative">

    <!-- Mobile menu toggle & Logo container -->
    <div class="flex items-center gap-3 sm:hidden">
      <button
        id="mobile-menu-toggle"
        class="sm:hidden text-muted-foreground hover:text-foreground shrink-0 focus:outline-none"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-sidebar"
      >
        <Menu size={18} />
      </button>

      <!-- F1 Logo -->
      <a href="/" class="flex items-center gap-2">
        <svg width="32" height="12" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <g fill="rgba(168,85,247,0.85)">
            <path d="M222.537,232.693h49.21l-0.469-12.424l-19.929-1.29c-0.423-0.062-0.782-0.359-0.938-0.782l-1.681-6.458c-0.141-0.399-0.078-0.86,0.156-1.212c0.25-0.351,0.657-0.563,1.095-0.563h18.951c-1.407-13.127-9.78-22.853-22.962-24.839c-18.741-2.815-33.228,10.602-30.93,26.708C215.978,218.386,219.261,228.714,222.537,232.693z"/>
            <path d="M65.417,237.509c-28.796,0-52.142,23.346-52.142,52.149c0,28.804,23.346,52.149,52.142,52.149c28.804,0,52.149-23.346,52.149-52.149C117.566,260.856,94.221,237.509,65.417,237.509z M65.417,317.156c-15.176,0-27.49-12.298-27.49-27.498c0-15.191,12.314-27.49,27.49-27.49c15.2,0,27.498,12.299,27.498,27.49C92.915,304.858,80.617,317.156,65.417,317.156z"/>
            <path d="M65.417,281.121c-4.707,0-8.522,3.831-8.522,8.538c0,4.715,3.815,8.538,8.522,8.538c4.715,0,8.546-3.823,8.546-8.538C73.963,284.952,70.132,281.121,65.417,281.121z"/>
            <path d="M393.738,229.965c-38.874-5.817-78.622-9.453-110.967-11.72c-2.291,10.148-9.75,19.264-19.186,19.264c-11.376,0-51.203,0-51.203,0v-22.751v-44.566c-61.97,6.756-101.288,39.296-124.165,64.268c21.658,8.976,36.942,30.336,36.942,55.198c0,5.583-0.79,10.977-2.228,16.122h214.946c-1.439-5.145-2.228-10.539-2.228-16.122C335.647,257.275,361.557,230.84,393.738,229.965z"/>
            <path d="M65.417,229.926c1.9,0,3.768,0.102,5.614,0.266l10.508-14.496v-33.173H0v83.439l8.741,4.902C16.646,247.111,39.061,229.926,65.417,229.926z"/>
            <path d="M470.281,286.813v-9.476l18.021-9.476c0,0,3.331-11.04,3.331-18.624c-21.219-7.005-49.57-11.102-75.738-15.684c22.862,8.397,39.217,30.375,39.217,56.105c0,5.583-0.79,10.977-2.236,16.122H512v-18.967H470.281z"/>
            <path d="M395.38,237.509c-28.796,0-52.15,23.346-52.15,52.149c0,28.804,23.354,52.149,52.15,52.149c28.804,0,52.149-23.346,52.149-52.149C447.529,260.856,424.184,237.509,395.38,237.509z M395.38,317.156c-15.192,0-27.498-12.298-27.498-27.498c0-15.191,12.306-27.49,27.498-27.49c15.184,0,27.498,12.299,27.498,27.49C422.878,304.858,410.564,317.156,395.38,317.156z"/>
            <path d="M395.38,281.121c-4.715,0-8.538,3.831-8.538,8.538c0,4.715,3.823,8.538,8.538,8.538c4.715,0,8.53-3.823,8.53-8.538C403.91,284.952,400.095,281.121,395.38,281.121z"/>
          </g>
        </svg>
        <span class="font-mono text-[9px] tracking-[0.18em] uppercase text-muted-foreground">f1 predict</span>
      </a>
    </div>

    <!-- Mobile Search & live status -->
    <div class="sm:hidden flex items-center gap-4">
      <button onclick="window.dispatchEvent(new Event('open-global-search'))" class="text-muted-foreground hover:text-foreground focus:outline-none">
        <Search size={16} />
      </button>
      <div class="flex items-center gap-1.5">
        <span class="relative flex h-[6px] w-[6px]">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#a855f7] opacity-50" />
          <span class="relative inline-flex rounded-full h-[6px] w-[6px] bg-[#a855f7]" />
        </span>
        <span class="font-mono text-[8px] tracking-[0.2em] text-[rgba(168,85,247,0.55)] uppercase">live</span>
      </div>
    </div>

    <!-- Desktop nav links -->
    <nav class="hidden sm:flex items-center gap-5 h-full">
      {links.map((link) => {
        const { href, label, icon: Icon, dropdown } = link as any;
        const active = isActive(href, dropdown);
        if (dropdown) {
          return (
            <div class="relative group h-full flex items-center">
              <a
                href={href}
                class={`flex items-center gap-1.5 font-mono text-[9px] tracking-[0.18em] uppercase transition-colors duration-150 ${
                  active ? 'text-[#a855f7]' : 'text-muted-foreground hover:text-foreground'
                }`}
              >
                <Icon size={12} />
                {label}
                <span class="text-[7px] ml-0.5 opacity-65 group-hover:rotate-180 transition-transform duration-200">▼</span>
              </a>

              {/* Dropdown panel */}
              <div class="absolute top-[44px] pt-1.5 left-1/2 -translate-x-1/2 hidden group-hover:block z-50 min-w-[120px]">
                <div class="border border-white/[0.08] bg-black py-1 shadow-[0_4px_12px_rgba(0,0,0,0.5)]">
                  {dropdown.map((sub: any) => (
                    <a
                      href={sub.href}
                      class="block px-4 py-2 font-mono text-[8px] tracking-[0.15em] uppercase text-muted-foreground hover:text-foreground hover:bg-white/[0.04] transition-colors duration-100"
                    >
                      {sub.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          );
        }
        return (
          <a
            href={href}
            class={`flex items-center gap-1.5 font-mono text-[9px] tracking-[0.18em] uppercase transition-colors duration-150 ${
              active ? 'text-[#a855f7]' : 'text-muted-foreground hover:text-foreground'
            }`}
          >
            <Icon size={12} />
            {label}
          </a>
        );
      })}
    </nav>

    <!-- Desktop Search Button -->
    <div class="hidden sm:flex absolute right-5 items-center h-full">
      <button onclick="window.dispatchEvent(new Event('open-global-search'))" class="flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors duration-150">
        <Search size={12} />
        <span class="font-mono text-[9px] tracking-[0.18em] uppercase">Search</span>
        <kbd class="hidden xl:inline-flex items-center gap-1 rounded border border-white/10 bg-white/5 px-1.5 font-mono text-[10px] font-medium text-muted-foreground opacity-100">
          <span class="text-[9px]">⌘K</span>
        </kbd>
      </button>
    </div>

  </div>
</header>

<!-- Mobile Sidebar Drawer -->
<div
  id="mobile-sidebar"
  class="fixed inset-y-0 left-0 z-50 w-[260px] bg-black/95 backdrop-blur-md border-r border-white/[0.08] transform -translate-x-full transition-transform duration-300 ease-in-out sm:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  tabindex="-1"
>
  <div class="flex flex-col h-full p-6 space-y-6">
    <!-- Header with Close Button -->
    <div class="flex items-center justify-between pb-4 border-b border-white/[0.06]">
      <div class="flex items-center gap-2">
        <span class="relative flex h-[6px] w-[6px]">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#a855f7] opacity-50" />
          <span class="relative inline-flex rounded-full h-[6px] w-[6px] bg-[#a855f7]" />
        </span>
        <span class="font-mono text-[9px] tracking-[0.25em] uppercase text-[#a855f7]">menu</span>
      </div>
      <button id="mobile-sidebar-close" class="text-muted-foreground hover:text-foreground focus:outline-none" aria-label="Close menu">
        <X size={16} />
      </button>
    </div>

    <!-- Nav Links -->
    <nav class="flex flex-col space-y-4">
      {links.map((link) => {
        const { href, label, icon: Icon, dropdown } = link as any;
        const active = isActive(href, dropdown);
        if (dropdown) {
          return (
            <div class="space-y-2">
              <button
                class="w-full flex items-center justify-between font-mono text-[10px] tracking-[0.18em] uppercase text-muted-foreground hover:text-white py-1.5 text-left mobile-dropdown-toggle focus:outline-none group"
                data-target={`mobile-dropdown-${label}`}
              >
                <span class="flex items-center gap-2.5">
                  <Icon size={13} className={active ? 'text-[#a855f7]' : ''} />
                  {label}
                </span>
                <span class="text-[7px] text-muted-foreground/60 transition-transform duration-200 group-hover:text-white">▼</span>
              </button>
              <div id={`mobile-dropdown-${label}`} class="hidden pl-4 border-l border-white/[0.06] flex flex-col space-y-3 mt-1">
                {dropdown.map((sub: any) => (
                  <a
                    href={sub.href}
                    class="block font-mono text-[9px] tracking-[0.15em] uppercase text-muted-foreground hover:text-white py-0.5 transition-colors"
                  >
                    {sub.label}
                  </a>
                ))}
              </div>
            </div>
          );
        }
        return (
          <a
            href={href}
            class={`flex items-center gap-2.5 font-mono text-[10px] tracking-[0.18em] uppercase py-1.5 transition-colors ${
              active ? 'text-[#a855f7]' : 'text-muted-foreground hover:text-white'
            }`}
          >
            <Icon size={13} />
            {label}
          </a>
        );
      })}
    </nav>
  </div>
</div>

<!-- Backdrop overlay -->
<div id="mobile-sidebar-backdrop" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-45 hidden sm:hidden transition-opacity duration-300 opacity-0" />

<GlobalSearch client:idle />

<script>
  function initMobileMenu() {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const closeBtn = document.getElementById('mobile-sidebar-close');
    const sidebar = document.getElementById('mobile-sidebar');
    const backdrop = document.getElementById('mobile-sidebar-backdrop');
    
    if (!toggleBtn || !sidebar || !backdrop) return;

    function getFocusable(): HTMLElement[] {
      return Array.from(
        sidebar!.querySelectorAll<HTMLElement>('a[href], button:not([disabled])')
      );
    }

    function trapFocus(e: KeyboardEvent) {
      if (e.key === 'Escape') {
        closeMenu();
        return;
      }
      if (e.key !== 'Tab') return;
      const focusable = getFocusable();
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }

    function openMenu() {
      sidebar.classList.remove('-translate-x-full');
      backdrop.classList.remove('hidden');
      toggleBtn!.setAttribute('aria-expanded', 'true');
      setTimeout(() => {
        backdrop.classList.add('opacity-100');
      }, 10);
      document.addEventListener('keydown', trapFocus);
      (getFocusable()[0] ?? sidebar).focus();
    }

    function closeMenu() {
      sidebar.classList.add('-translate-x-full');
      backdrop.classList.remove('opacity-100');
      toggleBtn!.setAttribute('aria-expanded', 'false');
      document.removeEventListener('keydown', trapFocus);
      setTimeout(() => {
        backdrop.classList.add('hidden');
      }, 300);
      toggleBtn!.focus();
    }

    toggleBtn.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);
    backdrop.addEventListener('click', closeMenu);

    // Handle accordion expands inside mobile menu
    const dropdownToggles = document.querySelectorAll('.mobile-dropdown-toggle');
    dropdownToggles.forEach(toggle => {
      toggle.addEventListener('click', (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const targetId = btn.getAttribute('data-target');
        const dropdownPanel = document.getElementById(targetId || '');
        const arrow = btn.querySelector('span:last-child');
        
        if (dropdownPanel) {
          const isHidden = dropdownPanel.classList.contains('hidden');
          if (isHidden) {
            dropdownPanel.classList.remove('hidden');
            dropdownPanel.classList.add('flex');
            if (arrow) arrow.classList.add('rotate-180');
          } else {
            dropdownPanel.classList.remove('flex');
            dropdownPanel.classList.add('hidden');
            if (arrow) arrow.classList.remove('rotate-180');
          }
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initMobileMenu);
</script>
